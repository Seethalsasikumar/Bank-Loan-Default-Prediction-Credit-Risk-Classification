df_final=pd.read_csv("Reduced_Data_FINAL.csv",index_col=0)

# train-test-split for lightGBM model
X_lgb = df_final.drop(columns=['BAD'])
y_lgb = df_final['BAD']

X_lgb_train, X_lgb_test, y_lgb_train, y_lgb_test = train_test_split(X_lgb, y_lgb, test_size=0.2, random_state=42, stratify=y_lgb)

# Define CV
stratified_cv = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)

# LightGBM model
model_lgb = lgb.LGBMClassifier(objective = 'binary',
                               boosting_type = 'gbdt',
                               metric = 'auc', 
                               is_unbalance  = 'true',
                               max_bin = 127, 
                               max_depth = 5,
                               num_leaves = 15,
                               n_estimators = 150, 
                               random_state = 42,
                               verbosity = -1)

%%time
# Hyperparameter tuning
# Define hyperparameter grid for tuning
param_grid = {
    'learning_rate': [0.05, 0.1],
    'feature_fraction': [0.5, 0.7],
    'bagging_fraction': [0.5, 0.7],
    'bagging_freq': [0, 1, 5]
    }
    
    
# Hyperparameter optimization using GridSearchCV
grid_search = GridSearchCV(model_lgb, param_grid, cv=stratified_cv, scoring="roc_auc", n_jobs=-1, verbose=2)

# Fit the model with hyperparameter optimization
grid_search.fit(X_lgb_train, y_lgb_train)

# Get the best hyperparameters from the grid search
best_params = grid_search.best_params_
print(f"Best hyperparameters found: {best_params}")
print(f"Best score: {grid_search.best_score_}")

# Get the best model from the grid search
best_model = grid_search.best_estimator_

%%time
# Cross-validation of final model for model comparison
cv_scores = cross_val_score(best_model, X_lgb_train, y_lgb_train,
                            cv=stratified_cv,                       
                            scoring='roc_auc', n_jobs=-1)
print(f"Cross-validated AUC scores: {cv_scores}")
print(f"Mean Cross-validated AUC: {cv_scores.mean():.4f} ± {cv_scores.std():.4f}")

# Train the best model on training set
best_model.fit(X_lgb_train, y_lgb_train)

# Predict probabilities on both the training and test sets
train_probs = best_model.predict_proba(X_lgb_train)[:, 1]
test_probs = best_model.predict_proba(X_lgb_test)[:, 1]

# Compute AUC for train and test sets
train_auc = roc_auc_score(y_lgb_train, train_probs)
test_auc = roc_auc_score(y_lgb_test, test_probs)

print(f"Train AUC: {train_auc:.4f}")
print(f"Test AUC: {test_auc:.4f}")

# Learning Curve
def plot_learning_curve(estimator, X, y, cv, scoring='roc_auc', train_sizes=np.linspace(0.1, 1.0, 5)):
    train_sizes, train_scores, val_scores = learning_curve(
        estimator, X, y, cv=cv, scoring=scoring,
        train_sizes=train_sizes, n_jobs=-1)

    train_scores_mean = np.mean(train_scores, axis=1)
    val_scores_mean = np.mean(val_scores, axis=1)

    plt.figure(figsize=(8, 6))
    plt.plot(train_sizes, train_scores_mean, 'o-', color="blue", label="Training score")
    plt.plot(train_sizes, val_scores_mean, 'o-', color="green", label="Validation score")

    plt.title("Learning Curve")
    plt.xlabel("Training examples")
    plt.ylabel(scoring.upper())
    plt.legend(loc="best")
    plt.grid()
    plt.show()
    
plot_learning_curve(best_model, X_lgb_train, y_lgb_train, cv=stratified_cv, scoring='roc_auc')

# predicted probability
y_pred = best_model.predict(X_lgb_test)
y_proba = best_model.predict_proba(X_lgb_test)[:,1]

# roc curve
fpr, tpr, _ = roc_curve(y_lgb_test, y_proba)
print('AUC:', roc_auc_score(y_lgb_test, y_proba))
print('KS:', max(tpr-fpr)) # evaluate the ability of identifying good/bad customers

plt.plot(fpr, tpr, label=f'LightGBM (AUC = {roc_auc_score(y_lgb_test, y_proba):.2f})')
plt.plot([0, 1], [0, 1], 'k--')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate (Recall)')
plt.title('ROC Curve')
plt.legend()
plt.grid(True)
plt.show()

# Precision-Recall Curve
precision, recall, thresholds = precision_recall_curve(y_lgb_test, y_proba)

# F1-score & accuracy as threshold changes
f1_scores = 2 * (precision * recall) / (precision + recall)
accuracy_scores = [accuracy_score(y_lgb_test, y_proba > threshold) for threshold in thresholds]

# Plot Precision, Recall, F1-score, Accuracy as threshold changes
plt.figure(figsize=(10, 6))
plt.plot(thresholds, precision[:-1], label='Precision', color='blue') # Precision vs Threshold
plt.plot(thresholds, recall[:-1], label='Recall', color='green') # Recall vs Threshold
plt.plot(thresholds, f1_scores[:-1], label='F1-score', color='red') # F1-score vs Threshold
plt.plot(thresholds, accuracy_scores, label='Accuracy', color='orange') # Accuracy vs Threshold
plt.title('Precision, Recall, F1-score, and Accuracy vs Threshold')
plt.xlabel('Threshold')
plt.ylabel('Score')
plt.legend(loc='best')
plt.grid(True)
plt.show()

