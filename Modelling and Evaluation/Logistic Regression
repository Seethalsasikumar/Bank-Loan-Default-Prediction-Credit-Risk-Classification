df_final=pd.read_csv("Reduced_Data_FINAL.csv",index_col=0)
# train-test-split for Logistic Regression model
X_lr = df_final.drop(columns=['BAD'])
y_lr = df_final['BAD']

X_lr_train, X_lr_test, y_lr_train, y_lr_test = train_test_split(X_lr, y_lr, test_size=0.2, random_state=42, stratify=y_lr)

# Define CV
stratified_cv = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)

# Scale
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_lr_train)
X_test_scaled = scaler.transform(X_lr_test)

# Logistic Regression Model
model_logreg = LogisticRegression(solver='liblinear', class_weight='balanced', random_state=42)

%%time
# Hyperparameter tuning
# Define hyperparameter grid for tuning
param_grid_lr = {
    'max_iter': [500, 1000],
    'penalty': ['l1', 'l2'],
    'C': [0.01, 0.1, 1, 10, 100]
    }
    
    
# Hyperparameter optimization using GridSearchCV
grid_search_lr = GridSearchCV(model_logreg, param_grid_lr, cv=stratified_cv, scoring="roc_auc", n_jobs=-1, verbose=2)

# Fit the model with hyperparameter optimization
grid_search_lr.fit(X_train_scaled, y_lr_train)

# Get the best hyperparameters from the grid search
best_params_lr = grid_search_lr.best_params_
print(f"Best hyperparameters found: {best_params_lr}")
print(f"Best score: {grid_search_lr.best_score_}")

# Get the best model from the grid search
best_model_lr = grid_search_lr.best_estimator_

%%time
# Cross-validation of final model for model comparison
cv_scores_lr = cross_val_score(best_model_lr, X_train_scaled, y_lr_train,
                            cv=stratified_cv,                       
                            scoring='roc_auc', n_jobs=-1)
print(f"Cross-validated AUC scores: {cv_scores_lr}")
print(f"Mean Cross-validated AUC: {cv_scores_lr.mean():.4f} ± {cv_scores_lr.std():.4f}")

# Train the best model on training set
best_model_lr.fit(X_train_scaled, y_lr_train)

# Predict probabilities on both the training and test sets
train_probs_lr = best_model_lr.predict_proba(X_train_scaled)[:, 1]
test_probs_lr = best_model_lr.predict_proba(X_test_scaled)[:, 1]

# Compute AUC for train and test sets
train_auc_lr = roc_auc_score(y_lr_train, train_probs_lr)
test_auc_lr = roc_auc_score(y_lr_test, test_probs_lr)

print(f"Train AUC: {train_auc_lr:.4f}")
print(f"Test AUC: {test_auc_lr:.4f}")

# Learning Curve
plot_learning_curve(best_model_lr, X_train_scaled, y_lr_train, cv=stratified_cv, scoring='roc_auc')

# predicted probability
y_pred = best_model_lr.predict(X_test_scaled)
y_proba = best_model_lr.predict_proba(X_test_scaled)[:,1]

# roc curve
fpr, tpr, _ = roc_curve(y_lr_test, y_proba)
print('AUC:', roc_auc_score(y_lr_test, y_proba))
print('KS:', max(tpr-fpr)) # evaluate the ability of identifying good/bad customers

plt.plot(fpr, tpr, label=f'Logistic Regression (AUC = {roc_auc_score(y_lr_test, y_proba):.2f})')
plt.plot([0, 1], [0, 1], 'k--')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate (Recall)')
plt.title('ROC Curve')
plt.legend()
plt.grid(True)
plt.show()

# Precision-Recall Curve
precision, recall, thresholds = precision_recall_curve(y_lr_test, y_proba)

# F1-score & accuracy as threshold changes
f1_scores = 2 * (precision * recall) / (precision + recall)
accuracy_scores = [accuracy_score(y_lr_test, y_proba > threshold) for threshold in thresholds]

# Plot Precision, Recall, F1-score, Accuracy as threshold changes
plt.figure(figsize=(10, 6))
plt.plot(thresholds, precision[:-1], label='Precision', color='blue') # Precision vs Threshold
plt.plot(thresholds, recall[:-1], label='Recall', color='green') # Recall vs Threshold
plt.plot(thresholds, f1_scores[:-1], label='F1-score', color='red') # F1-score vs Threshold
plt.plot(thresholds, accuracy_scores, label='Accuracy', color='orange') # Accuracy vs Threshold
plt.title('Precision, Recall, F1-score, and Accuracy vs Threshold')
plt.xlabel('Threshold')
plt.ylabel('Score')
plt.legend(loc='best')
plt.grid(True)
plt.show()

## Question 1

best_thresh_1 = None
best_good_accept_rate_1 = 0

best_thresh_2 = None
best_bad_reject_rate_2 = 0

thresholds_q1 = np.arange(0.01, 1.0, 0.01)

print("§§§§ Task1: Max Recall(class=0) when Recall(class=1) ≥ 0.85 §§§§")
for t in thresholds_q1:
    y_pred = (y_proba >= t).astype(int)
    cm = confusion_matrix(y_lr_test, y_pred)
    
    recall_1 = recall_score(y_lr_test, y_pred, pos_label=1)  
    recall_0 = recall_score(y_lr_test, y_pred, pos_label=0)  

    if recall_1 >= 0.85 and recall_0 > best_good_accept_rate_1:
        best_thresh_1 = t
        best_good_accept_rate_1 = recall_0
        best_cm_1 = cm

        print(f"Threshold={t:.2f} | Recall(class=1)={recall_1:.2f}, Recall(class=0)={recall_0:.2f}")
        print(f"\nConfusion Matrix:\n{best_cm_1}")

print("\n§§§§ Task2: Max Recall(class=1）when Recall(class=0) ≥ 0.70 §§§§")
for t in thresholds_q1:
    y_pred = (y_proba >= t).astype(int)
    cm = confusion_matrix(y_lr_test, y_pred)
    
    recall_1 = recall_score(y_lr_test, y_pred, pos_label=1) 
    recall_0 = recall_score(y_lr_test, y_pred, pos_label=0)

    if recall_0 >= 0.70 and recall_1 > best_bad_reject_rate_2:
        best_thresh_2 = t
        best_bad_reject_rate_2 = recall_1
        best_cm_2 = cm

        print(f"Threshold={t:.2f} | Recall(class=0)={recall_0:.2f}, Recall(class=1)={recall_1:.2f}")
        print(f"\nConfusion Matrix:\n{best_cm_2}")

final_thresh_1 = best_thresh_1
y_final_pred_1 = (y_proba >= final_thresh_1).astype(int)
print(f"Classification report at threshold={final_thresh_1:.2f}:\n{classification_report(y_lr_test, y_final_pred_1)}")

final_thresh_2 = best_thresh_2
y_final_pred_2 = (y_proba >= final_thresh_2).astype(int)
print(f"Classification report at threshold={final_thresh_2:.2f}:\n{classification_report(y_lr_test, y_final_pred_2)}")

