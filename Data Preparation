## Applying Box Cox,Log and Square root Transformations
#### - Given the high skewness of the data, data transformation techniques have been applied to get close to a normal distribution.
#### - Due to the high skewness of the data (predominantely right-skewed), the Box-Cox transformation with its special cases (Log and sqrt transformations) were used. These transformations are known for being efficient in compressing positively-skewed data.
#### - Lastly, Z-score approach was applied to detect and remove outliers. After applying the above transformations and moving the data close to a normal distribution, Z-score approach was efficient knowing that it is mainly applied on normally distributed data.


## Log, Square root, and Box-Cox Transformation

### The below code applies one of the above transformations based on the skewness level and min value of each column

def transform_column_by_skew(data_to_reduce, numerical_cols):

    df_transformed = data_to_reduce.copy()

    for col in numerical_cols:
        if col in df_transformed.columns:
            skew_val = df_transformed[col].skew()

            print(f"\n--- Processing column: {col} ---")
            print(f"Skewness before transformation: {skew_val:.4f}")
            print(f"Minimum value before transformation: {df_transformed[col].min():.4f}")

            if skew_val > 1:
                # Log transform if data is positive and min value >= 1, otherwise use Box-Cox
                min_val = df_transformed[col].min()
                if min_val < 1:
                    print(f"Column {col} has values less than 1. Using Box-Cox instead of log.")
                    df_transformed[col], _ = boxcox(df_transformed[col] - df_transformed[col].min() + 1)
                    trans = 'boxcox'
                else:
                    df_transformed[col] = np.log(df_transformed[col])
                    trans = 'log'
                    print(f"Transformation applied: {trans}")
            elif 0.5 < skew_val <= 1:
                min_val = df_transformed[col].min()
                shift = 0 if min_val >= 0 else -min_val
                df_transformed[col] = np.sqrt(df_transformed[col] + shift)
                trans = 'sqrt'
                print(f"Due to moderate positive skewness, transformation applied: {trans}")
            elif -1.0 <= skew_val < -0.5:
                # Apply inverse square root transformation for moderately negative skew
                max_val = df_transformed[col].max()
                shift = max_val if max_val <= 0 else 0 #shift 0 if max is positive else shift by max
                df_transformed[col] = 1 / np.sqrt(df_transformed[col] + shift)
                trans = "inv_sqrt"
                print(f"Due to moderate negative skewness, transformation applied: {trans}")
            elif skew_val < -1:
                max_val = df_transformed[col].max()
                shift = max_val if max_val <= 0 else 0
                df_transformed[col] = 1 / (df_transformed[col] + shift)
                trans = "inv_transformation"
                print(f"Due to high negative skewness, transformation applied: {trans}")
            else:
                trans = "none"  # No transformation applied
                print(f"Normal skewness. No transformation applied.")
            

            if (df_transformed[col] < 0).any():
                print(f" Column {col} has negative values after {trans} transformation.")
                print("First 5 negative values after transformation:")
                print(df_transformed[df_transformed[col] < 0][col].head())
        else:
            print(f"Warning: Column '{col}' not found in the DataFrame.")
    return df_transformed
    

